# Telegram bot credentials (create a bot via @BotFather, then get chat id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional overrides
OFFICE_NAME=REGISTRO CIVIL EXCLUSIVO N.º 1 DE SEVILLA
TRAMITE_NAME=REQUISITOS JURAMENTO/PROMESA NACIONALIDAD POR RESIDENCIA
MAX_MONTHS=6
HEADLESS=true
SAVE_DEBUG=false
DEBUG_DIR=debug

# Set to "true" to send a Telegram message even when no slots are found
FORCE_NOTIFY=false

# Server (server.js / index.js)
PORT=3000
HOST=0.0.0.0
# Interval between automated checks when running as a server (ms). Default 7 min.
CHECK_INTERVAL_MS=420000
# Set to "false" to skip the initial check on startup
RUN_ON_START=true
# Optional shared secret to protect the /check endpoint: call /check?key=...
TRIGGER_KEY=

# Set to "true" on Hostinger / shared Linux hosts where Playwright's bundled
# Chromium fails for missing system libs. Uses @sparticuz/chromium portable
# binary instead. Leave unset for local dev (Mac/Win/Linux desktop).
USE_SPARTICUZ=false
