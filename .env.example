# Telegram bot credentials (create a bot via @BotFather, then get chat id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional overrides
OFFICE_NAME=REGISTRO CIVIL EXCLUSIVO N.º 1 DE SEVILLA
TRAMITE_NAME=REQUISITOS JURAMENTO/PROMESA NACIONALIDAD POR RESIDENCIA
MAX_MONTHS=6
HEADLESS=true
SAVE_DEBUG=false
DEBUG_DIR=debug

# TEMP: set to "true" to send a Telegram message even when no slots are found
FORCE_NOTIFY=false

# Server (server.js)
PORT=3000
HOST=0.0.0.0
# Interval between automated checks when running as a server (ms). Default 15 min.
CHECK_INTERVAL_MS=900000
# Set to "false" to skip the initial check on startup
RUN_ON_START=true
# Optional shared secret to protect the /check endpoint: call /check?key=...
TRIGGER_KEY=
